SHOPIFY_APP_URL=https://your-app.vercel.app/
APP_URL=https://your-app.vercel.app/
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SCOPES=read_products,write_products,read_content,write_content,write_files,read_files,read_themes,write_themes,write_online_store_navigation
DATABASE_URL="mysql://user:password@host:3306/database"
SESSION_SECRET=your-session-secret
NODE_ENV=production

# Billing plans
SHOPIFY_BILLING_TEST=true

BILLING_FREE_PRICE=0
BILLING_FREE_CREDITS=150
BILLING_STARTER_PRICE=9.99
BILLING_STARTER_CREDITS=1500
BILLING_GROWTH_PRICE=14.99
BILLING_GROWTH_CREDITS=5000

# Extra credit one-time purchases
EXTRA_CREDITS_SMALL_PRICE=5
EXTRA_CREDITS_SMALL_CREDITS=1000
EXTRA_CREDITS_MEDIUM_PRICE=20
EXTRA_CREDITS_MEDIUM_CREDITS=5000
EXTRA_CREDITS_LARGE_PRICE=50
EXTRA_CREDITS_LARGE_CREDITS=15000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Product AI Generate <your-email@gmail.com>
APP_OWNER_EMAIL=your-email@gmail.com

# ── AI Provider API Keys ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
COHERE_API_KEY=your-cohere-api-key

# AI Provider routing
DEFAULT_AI_PROVIDER=gemini
FALLBACK_AI_PROVIDER=openai

# Model versions (optional — these are the defaults if not set)
GEMINI_MODEL=gemini-2.5-flash-lite
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# ── Inngest — required for background bulk generation ─────────────────────────
# Get these from https://app.inngest.com → your app → API Keys
INNGEST_EVENT_KEY=...
INNGEST_SIGNING_KEY=...

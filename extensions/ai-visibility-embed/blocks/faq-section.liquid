{%- liquid
  assign bid = block.id
  assign title = block.settings.title | default: 'Frequently Asked Questions'
  assign subheading = block.settings.subheading
  assign bg_color = block.settings.background_color
  assign heading_color = block.settings.heading_color
  assign text_color = block.settings.text_color
  assign open_first = block.settings.open_first
  assign show_divider = block.settings.show_divider

  assign faq_items = nil
  if product
    assign faq_meta = product.metafields.content_ai_geo.faq_json
    if faq_meta != blank
      assign faq_items = faq_meta.value.mainEntity
    endif
  endif
-%}

{%- if faq_items != blank and faq_items.size > 0 -%}

<style>
  #cai-faq-{{ bid }} {
    background-color: {{ bg_color }};
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }
  #cai-faq-{{ bid }} .cai-faq__inner {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
    box-sizing: border-box;
  }
  #cai-faq-{{ bid }} .cai-faq__heading {
    text-align: center;
    font-size: clamp(1.25rem, 3vw, 1.65rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ heading_color }};
  }
  #cai-faq-{{ bid }} .cai-faq__subheading {
    text-align: center;
    font-size: 1rem;
    color: {{ block.settings.subheading_color }};
    margin: -8px 0 24px;
  }
  #cai-faq-{{ bid }} .cai-faq__list {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_gap }}px;
  }
  #cai-faq-{{ bid }} .cai-faq__item {
    background-color: {{ block.settings.card_bg }};
    border: 1px solid {{ block.settings.card_border }};
    border-radius: {{ block.settings.card_radius }}px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    overflow: hidden;
  }
  #cai-faq-{{ bid }} .cai-faq__item--divider {
    background-color: transparent;
    border: none;
    border-bottom: 1px solid {{ block.settings.card_border }};
    border-radius: 0;
    box-shadow: none;
  }
  #cai-faq-{{ bid }} .cai-faq__item--divider:first-child {
    border-top: 1px solid {{ block.settings.card_border }};
  }
  #cai-faq-{{ bid }} .cai-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: {{ block.settings.item_pad_v }}px {{ block.settings.item_pad_h }}px;
    cursor: pointer;
    list-style: none;
    user-select: none;
    -webkit-tap-highlight-color: transparent;
  }
  #cai-faq-{{ bid }} .cai-faq__summary::-webkit-details-marker { display: none; }
  #cai-faq-{{ bid }} .cai-faq__summary::marker { display: none; }
  #cai-faq-{{ bid }} .cai-faq__question {
    flex: 1;
    font-size: {{ block.settings.question_size }}px;
    font-weight: {{ block.settings.question_weight }};
    color: {{ text_color }};
    line-height: 1.4;
  }
  #cai-faq-{{ bid }} .cai-faq__chevron {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid #c8c8c8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    transition: transform 0.25s ease, border-color 0.2s ease, color 0.2s ease;
  }
  #cai-faq-{{ bid }} .cai-faq__item[open] .cai-faq__chevron {
    transform: rotate(180deg);
    border-color: {{ block.settings.accent_color }};
    color: {{ block.settings.accent_color }};
  }
  #cai-faq-{{ bid }} .cai-faq__answer {
    padding: 0 {{ block.settings.item_pad_h }}px {{ block.settings.item_pad_v }}px;
    font-size: {{ block.settings.answer_size }}px;
    color: {{ text_color }};
    line-height: 1.7;
    opacity: 0.85;
  }
  #cai-faq-{{ bid }} .cai-faq__answer p { margin: 0 0 10px; }
  #cai-faq-{{ bid }} .cai-faq__answer p:last-child { margin: 0; }
  #cai-faq-{{ bid }} .cai-faq__answer ul,
  #cai-faq-{{ bid }} .cai-faq__answer ol { margin: 0 0 10px; padding-left: 20px; }
  #cai-faq-{{ bid }} .cai-faq__answer li { margin-bottom: 4px; }
  #cai-faq-{{ bid }} .cai-faq__answer a { color: {{ block.settings.accent_color }}; }
</style>

{%- capture faq_chevron -%}
<span class="cai-faq__chevron" aria-hidden="true">
  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
       viewBox="0 0 24 24" fill="none" stroke="currentColor"
       stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
    <polyline points="6 9 12 15 18 9"/>
  </svg>
</span>
{%- endcapture -%}

<div id="cai-faq-{{ bid }}" class="cai-faq-block" {{ block.shopify_attributes }}>
  <div class="cai-faq__inner">
    {%- if title != blank -%}
      <h2 class="cai-faq__heading">{{ title | escape }}</h2>
    {%- endif -%}

    {%- if subheading != blank -%}
      <p class="cai-faq__subheading">{{ subheading }}</p>
    {%- endif -%}

    {%- assign item_class = 'cai-faq__item' -%}
    {%- if show_divider -%}
      {%- assign item_class = 'cai-faq__item cai-faq__item--divider' -%}
    {%- endif -%}

    <div class="cai-faq__list">
      {%- for entity in faq_items -%}
        {%- assign question = entity.name -%}
        {%- assign answer = entity.acceptedAnswer.text -%}
        {%- if question != blank and answer != blank -%}
          <details class="{{ item_class }}"{% if open_first and forloop.first %} open{% endif %}>
            <summary class="cai-faq__summary">
              <span class="cai-faq__question">{{ question | escape }}</span>{{ faq_chevron }}
            </summary>
            <div class="cai-faq__answer">{{ answer }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- endif -%}

{% schema %}
{
  "name": "FAQ Section",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#6b7280"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border color",
      "default": "#e5e7eb"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#6366f1"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "Space below heading",
      "min": 8,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Max content width",
      "min": 480,
      "max": 1200,
      "step": 40,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "FAQ items"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open first item by default",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Use divider style instead of cards",
      "default": false
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Space between items",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "item_pad_v",
      "label": "Item vertical padding",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "item_pad_h",
      "label": "Item horizontal padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "question_size",
      "label": "Question font size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "select",
      "id": "question_weight",
      "label": "Question font weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "answer_size",
      "label": "Answer font size",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ]
}
{% endschema %}

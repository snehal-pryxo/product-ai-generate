// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model shop {
  id            Int       @id @default(autoincrement())
  shop          String    @unique(map: "Shop_shop_key")
  accessToken   String?
  installed     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  onboardedAt   DateTime?
  uninstalledAt DateTime?
  status                  String?   @default("installed") @db.VarChar(32)
   ownerName               String?   @db.VarChar(255)
  email                   String?   @db.VarChar(320)
  contactEmail            String?   @db.VarChar(320)
  name                    String?   @db.VarChar(255)
  country                 String?   @db.VarChar(100)
  city                    String?   @db.VarChar(100)
  currency                String?   @db.VarChar(10)
  phone                   String?   @db.VarChar(50)
  primaryDomain           String?   @db.VarChar(255)
  openaiApiKey            String?   @db.VarChar(255)
  anthropicApiKey         String?   @db.VarChar(255)
  geminiApiKey            String?   @db.VarChar(255)
  defaultAiProvider       String?   @default("auto") @db.VarChar(32)
  defaultAiModel          String?   @default("gpt-4o-mini") @db.VarChar(100)
  credits                 Int       @default(150)
  creditsUsedTotal        Int       @default(0)
  billingPlanKey          String?   @default("free") @db.VarChar(32)
  billingPlanName         String?   @default("Free") @db.VarChar(100)
  billingPlanCredits      Int       @default(150)
  billingPlanPrice        Decimal?  @db.Decimal(10, 2)
  billingSubscriptionId   String?   @db.VarChar(255)
  billingSubscriptionStatus String? @db.VarChar(32)
  billingPlanActivatedAt  DateTime?
  billingCreditsRenewedAt DateTime?
  freePlanUsedAt          DateTime?
  reviewSubmittedAt       DateTime?
  reviewPromptDismissedAt DateTime?
  reviewRating            Int?
  reviewFeedback          String?   @db.Text
  globalSettingsJson      String?   @db.LongText
  templateSelectionsJson  String?   @db.LongText
  customPromptTemplatesJson String? @db.LongText
  themeEmbedEnabled       Boolean   @default(false)
}

model BillingSubscription {
  id             BigInt    @id @default(autoincrement())
  shop           String
  planKey        String    @db.VarChar(32)
  planName       String    @db.VarChar(100)
  credits        Int
  price          Decimal   @db.Decimal(10, 2)
  subscriptionId String?   @unique(map: "BillingSubscription_subscriptionId_key") @db.VarChar(255)
  status         String    @default("PENDING") @db.VarChar(32)
  creditedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([shop, createdAt], map: "BillingSubscription_shop_createdAt_idx")
  @@map("billing_subscriptions")
}

model BillingCreditPurchase {
  id          BigInt    @id @default(autoincrement())
  shop        String
  packageKey  String    @db.VarChar(32)
  name        String    @db.VarChar(100)
  credits     Int
  price       Decimal   @db.Decimal(10, 2)
  purchaseId  String?   @unique(map: "BillingCreditPurchase_purchaseId_key") @db.VarChar(255)
  status      String    @default("PENDING") @db.VarChar(32)
  creditedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop, createdAt], map: "BillingCreditPurchase_shop_createdAt_idx")
  @@map("billing_credit_purchases")
}

model GeneratedContentLog {
  id                     BigInt    @id @default(autoincrement())
  shop                   String
  productId              String
  productTitle           String?
  intent                 String
  resourceType           String?   @db.VarChar(32)
  language               String?
  tone                   String?
  lengthOption           String?
  formatOption           String?
  contextKeywords        String?   @db.Text
  aiModel                String?
  aiProvider             String?   @db.VarChar(32)
  inputTokens            Int       @default(0)
  outputTokens           Int       @default(0)
  generationMs           Int?
  generatedDescription   String?   @db.LongText
  generatedSeoTitle      String?
  generatedSeoDescription String?  @db.Text
  creditsUsed            Int       @default(0)
  appliedToProduct       Boolean   @default(false)
  createdAt              DateTime  @default(now())

  @@index([shop, productId, createdAt], map: "GeneratedContentLog_shop_product_createdAt_idx")
  @@map("generated_content_logs")
}

model ProductGeneratedContent {
  id              BigInt   @id @default(autoincrement())
  shop            String
  productId       String
  productTitle    String?
  language        String?
  tone            String?
  lengthOption    String?
  formatOption    String?
  contextKeywords String?  @db.Text
  descriptionPromptTemplate String? @db.LongText
  metaTitlePromptTemplate  String? @db.Text
  metaDescriptionPromptTemplate String? @db.Text
  aiModel         String?
  aiProvider      String?  @db.VarChar(32)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  generationMs    Int?
  descriptionHtml String?  @db.LongText
  faqHtml         String?  @db.LongText
  faqJson         String?  @db.LongText
  seoTitle        String?
  seoDescription  String?  @db.Text
  creditsUsed     Int      @default(0)
  appliedToProduct Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, productId], map: "ProductGeneratedContent_shop_productId_key")
  @@index([shop, updatedAt], map: "ProductGeneratedContent_shop_updatedAt_idx")
  @@map("product_generated_contents")
}

model PageGeneratedContent {
  id              BigInt   @id @default(autoincrement())
  shop            String
  pageId          String
  pageTitle       String?
  pageType        String?
  language        String?
  tone            String?
  lengthOption    String?
  formatOption    String?
  contextKeywords String?  @db.Text
  bodyPromptTemplate String? @db.LongText
  metaTitlePromptTemplate String? @db.Text
  metaDescriptionPromptTemplate String? @db.Text
  aiModel         String?
  aiProvider      String?  @db.VarChar(32)
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  generationMs    Int?
  bodyHtml        String?  @db.LongText
  seoTitle        String?
  seoDescription  String?  @db.Text
  creditsUsed     Int      @default(0)
  appliedToPage   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, pageId], map: "PageGeneratedContent_shop_pageId_key")
  @@index([shop, updatedAt], map: "PageGeneratedContent_shop_updatedAt_idx")
  @@map("page_generated_contents")
}

model CollectionGeneratedContent {
  id                BigInt   @id @default(autoincrement())
  shop              String
  collectionId      String
  collectionTitle   String?
  language          String?
  tone              String?
  lengthOption      String?
  formatOption      String?
  contextKeywords   String?  @db.Text
  descriptionPromptTemplate String? @db.LongText
  metaTitlePromptTemplate String? @db.Text
  metaDescriptionPromptTemplate String? @db.Text
  aiModel           String?
  aiProvider        String?  @db.VarChar(32)
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  generationMs      Int?
  descriptionHtml   String?  @db.LongText
  seoTitle          String?
  seoDescription    String?  @db.Text
  creditsUsed       Int      @default(0)
  appliedToCollection Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, collectionId], map: "CollectionGeneratedContent_shop_collectionId_key")
  @@index([shop, updatedAt], map: "CollectionGeneratedContent_shop_updatedAt_idx")
  @@map("collection_generated_contents")
}

model CollectionProductGeneratedContent {
  id                BigInt   @id @default(autoincrement())
  shop              String
  collectionId      String
  collectionTitle   String?
  productId         String
  productTitle      String?
  language          String?
  tone              String?
  lengthOption      String?
  formatOption      String?
  contextKeywords   String?  @db.Text
  descriptionPromptTemplate String? @db.LongText
  metaTitlePromptTemplate String? @db.Text
  metaDescriptionPromptTemplate String? @db.Text
  aiModel           String?
  aiProvider        String?  @db.VarChar(32)
  inputTokens       Int      @default(0)
  outputTokens      Int      @default(0)
  generationMs      Int?
  descriptionHtml   String?  @db.LongText
  seoTitle          String?
  seoDescription    String?  @db.Text
  creditsUsed       Int      @default(0)
  appliedToProduct  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([shop, collectionId, productId], map: "CollectionProductGeneratedContent_shop_collection_product_key")
  @@index([shop, collectionId, updatedAt], map: "CollectionProductGeneratedContent_shop_collection_updatedAt_idx")
  @@map("collection_product_generated_contents")
}

model BlogGeneratedContent {
  id             BigInt   @id @default(autoincrement())
  shop           String
  blogId         String?
  articleId      String
  title          String   @db.VarChar(255)
  summary        String?  @db.Text
  bodyHtml       String?  @db.LongText
  status         String?  @db.VarChar(32)
  language       String?
  tone           String?
  lengthOption   String?
  targetAudience String?
  tabType        String?  @db.VarChar(64)
  topic          String?  @db.VarChar(255)
  promotion      String?
  offerText      String?  @db.VarChar(255)
  holiday        String?
  productUrl     String?  @db.Text
  aiModel        String?  @db.VarChar(100)
  aiProvider     String?  @db.VarChar(32)
  contextKeywords String? @db.Text
  formatOption   String?  @db.VarChar(64)
  inputTokens    Int      @default(0)
  outputTokens   Int      @default(0)
  generationMs   Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([shop, articleId], map: "BlogGeneratedContent_shop_articleId_key")
  @@index([shop, updatedAt], map: "BlogGeneratedContent_shop_updatedAt_idx")
  @@map("blog_generated_contents")
}

model BulkJob {
  id               String    @id @default(cuid())
  shop             String
  jobType          String    // "product" | "collection" | "collection_product"
  status           String    @default("pending") // "pending" | "processing" | "completed" | "partial" | "failed"
  totalItems       Int
  completedItems   Int       @default(0)
  failedItems      Int       @default(0)
  contentTypes     String    @db.Text // JSON: ["description","meta_title","meta_description"]
  settings         String    @db.LongText // JSON: { language, tone, ... }
  itemsData        String    @db.LongText // JSON: array of items
  creditsAllocated Int
  creditsUsed      Int       @default(0)
  failedItemIds      String?   @db.LongText // JSON: [{id, title, error}]
  completedItemIds   String?   @db.LongText // JSON: [{id, title}]
  createdAt          DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  completedAt      DateTime?

  @@index([shop, createdAt], map: "bulk_jobs_shop_createdAt_idx")
  @@map("bulk_jobs")
}

model AiVisibilitySchema {
  id           BigInt   @id @default(autoincrement())
  shop         String
  resourceType String   @db.VarChar(32)
  resourceId   String   @db.VarChar(255)
  schemaType   String   @db.VarChar(64)
  schemaJson   String   @db.LongText
  metafieldId  String?  @db.VarChar(255)
  aiModel      String?  @db.VarChar(100)
  aiProvider   String?  @db.VarChar(32)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  creditsUsed  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, resourceType, resourceId], map: "AiVisibilitySchema_shop_type_resource_key")
  @@map("ai_visibility_schemas")
}

model AiVisibilityFaq {
  id           BigInt   @id @default(autoincrement())
  shop         String
  resourceType String   @db.VarChar(32)
  resourceId   String   @db.VarChar(255)
  faqJson      String   @db.LongText
  metafieldId  String?  @db.VarChar(255)
  aiModel      String?  @db.VarChar(100)
  aiProvider   String?  @db.VarChar(32)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  creditsUsed  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([shop, resourceType, resourceId], map: "AiVisibilityFaq_shop_type_resource_key")
  @@map("ai_visibility_faqs")
}

model AiVisibilityLlmsTxt {
  id           BigInt   @id @default(autoincrement())
  shop         String   @unique(map: "AiVisibilityLlmsTxt_shop_key")
  content      String   @db.LongText
  agentContent String?  @db.LongText
  itemCount    Int?
  aiModel      String?  @db.VarChar(100)
  aiProvider   String?  @db.VarChar(32)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  creditsUsed  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ai_visibility_llms_txt")
}
